# 服务端口（生产 / 开发 BFF 均适用）
PORT=3001

# 生产环境建议设置
# NODE_ENV=production

# 开发时前后端分离、跨域访问 API 时配置（逗号分隔）
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- 日报推送（本地 npm run report:daily:push 或 GitHub Actions Secrets）---
# 推送格式：html=卡片按钮打开完整 HTML（默认）；markdown=纯文本摘要
# NOTIFY_FORMAT=html
# IM 正文最大字符（完整 MD，超出会截断并提示看 HTML）
# NOTIFY_IM_MAX_CHARS=28000
# 钉钉是否额外发第二条 HTML 按钮卡片（默认 false，链接已在正文末尾）
# DINGTALK_HTML_BUTTON=false
# 公网 HTML 地址（二选一）：完整 URL 或 目录前缀（文件名自动拼接）
# REPORT_HTML_URL=https://你的域名/reports/YXStock_行情日报_2026-05-26.html
# REPORT_HTML_BASE_URL=https://yxstock.netlify.app/reports
# GitHub Actions 推送前会 commit reports/，并生成 htmlpreview 链接（REPORT_USE_GITHUB_RAW=true）
# 逗号分隔：dingtalk,feishu,wechat
# NOTIFY_CHANNELS=dingtalk,feishu
# NOTIFY_ON_GENERATE=true
# 同步 HTML 到 apps/web/public/reports/latest.html（配合 Netlify 部署）
# COPY_REPORT_TO_WEB_PUBLIC=true

# 钉钉：默认只填 Webhook（正文会自动带关键词「热点」）
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# 仅当启用加签，或关键词不是「热点」时再配置：
# DINGTALK_SECRET=
# DINGTALK_KEYWORD=热点
# 设为 true 时钉钉用纯文本（会显示 ** 等符号，一般不要开）
# DINGTALK_PREFER_TEXT=false

# 飞书自定义机器人（若设置了关键词安全校验，填 FEISHU_KEYWORD）
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# FEISHU_KEYWORD=日报

# 企业微信群机器人（个人微信请用企业微信或第三方，见 README）
# WECHAT_WORK_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# 推送正文附仓库链接（GitHub Actions 会自动注入）
# REPORT_REPO_URL=https://github.com/you/YXStock
